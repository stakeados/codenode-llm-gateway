# ==========================================
# ENV TEMPLATE FOR LLM-GATEWAY v3.0 (CodeNode.cloud)
# ==========================================

# Puerto interno del servicio (3000 por defecto para coincidir con manifest.json)
PORT=3000

# Proxy Key secreta para proteger los endpoints. Evitar accesos no autorizados.
API_PROXY_KEY=

# Si es true, el endpoint devolverá 402 Payment Required simulando integración x402.
# Si es false o está vacío, opera de forma libre.
REQUIRE_PAYMENT=false
# ==========================================
# EMERGENCY FALLBACK
# ==========================================

# Phase 2: Free provider retry. This provider gets one final retry after ALL others fail.
# Valid values: Groq, Cerebras, Gemini, OpenRouter, DeepSeek, Mistral, Nvidia, GithubModels
EMERGENCY_PROVIDER=OpenRouter

# Phase 3: PAID emergency API. Absolute last resort — costs real money.
# Only used if ALL free providers (including Phase 2) have failed.
# Accepts any OpenAI-compatible API (OpenAI, Anthropic via proxy, etc.)
EMERGENCY_API_KEY=
EMERGENCY_API_URL=https://api.openai.com/v1/chat/completions
EMERGENCY_MODEL=gpt-4o-mini

# ==========================================
# API KEYS DE PROVEEDORES (BYOK)
# ==========================================
# MULTI-KEY: Puedes poner varias keys separadas por comas para multiplicar
# tus límites gratuitos:  GROQ_API_KEY=key1,key2,key3
# También puedes usar variables numeradas: GROQ_API_KEY_1=key1  GROQ_API_KEY_2=key2

# OpenRouter (Acceso a decenas de modelos, incluyendo varios gratuitos como Qwen)
OPENROUTER_API_KEY=

# Groq (Inferencia ultra-rápida LPU)
GROQ_API_KEY=

# Cerebras (Modelos open source acelerados por hardware)
CEREBRAS_API_KEY=

# Google Gemini (Acceso a modelos de Google AI Studio)
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek (Gran rendimiento y razonamiento económico)
DEEPSEEK_API_KEY=

# ─── NUEVOS PROVEEDORES (v3.0) ───


# Mistral (La Plateforme — free tier para mistral-small)
MISTRAL_API_KEY=

# NVIDIA NIM (build.nvidia.com — free credits on signup, Llama/Nemotron models)
NVIDIA_API_KEY=

# GitHub Models (free for GitHub users — uses your GitHub PAT, no special scopes needed)
# Get a token at: https://github.com/settings/tokens
GITHUB_MODELS_API_KEY=
